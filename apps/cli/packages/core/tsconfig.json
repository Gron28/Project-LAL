{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "tsBuildInfoFile": "tsconfig.tsbuildinfo",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "composite": true,
    "types": ["node", "vitest/globals"],
    "paths": {
      "@lydell/node-pty": ["../../node_modules/@lydell/node-pty/node-pty.d.ts"]
