{
  "compilerOptions": {
    "target": "ES2019",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    // Lets test/tooling files import sibling .ts files with an explicit extension (as
    // web/src/lib/protocol/protocol.conformance.test.ts does), so they can also be run
    // directly by Node's native TypeScript support (`node --test`), which requires
    // fully-specified module paths. Safe only because noEmit is true above.
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    ".next-recovery/types/**/*.ts",
    ".next-recovery/dev/types/**/*.ts",
    ".next-recovery2/types/**/*.ts",
    ".next-recovery2/dev/types/**/*.ts",
    ".next-recovery3/types/**/*.ts",
    ".next-recovery3/dev/types/**/*.ts",
    ".next-recovery4/types/**/*.ts",
    ".next-recovery4/dev/types/**/*.ts",
    ".next-recovery5/types/**/*.ts",
    ".next-recovery5/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
