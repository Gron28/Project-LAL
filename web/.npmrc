# @project-lal/protocol (packages/protocol) is a file: dependency that lives
# outside web/'s Turbopack root. Turbopack refuses to resolve symlinks that
# point outside its project root, and widening that root to the monorepo root
# hits an unrelated broken-symlink panic under .venv. install-links makes npm
# copy the dependency's files into node_modules instead of symlinking, so it
# resolves as a normal in-root package.
install-links=true
