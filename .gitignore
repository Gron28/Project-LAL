# big artifacts — never commit weights/binaries/venvs
.venv/
.venv-rocm/
llama/
# the trained-model GGUF dir at the repo root — anchored so it doesn't also swallow
# source paths like web/src/app/api/agent/models/ (that bug hid the models route).
/models/
out/
# skill-registry tool cache
.atl/
# scratch: the coding agent's own working directory (runtime output, not source)
/workspace/
/.data/
data/*.bin
*.gguf
*.safetensors
*.log
Modelfile
__pycache__/
*.pyc
.DS_Store
web_scaffold.log

# Generated LAL release payloads are reproducible via `./start.sh --release-lal`.
# Keeping the ~60 MB archives out of Git makes normal updates and clones fast.
web/public/lal/releases/

# build artifacts / installed deps for Project-LAL apps and temporary workspaces
node_modules/
.next/
.next-recovery*/

# Runtime datasets are intentionally local. Commit only explicit small fixtures.
/data/*.jsonl
/data/*.json
/data/sovereign_batches/

# Local session config and CLI test-run side-effect directories
/.qwen/
/apps/cli/packages/cli/custom/
/apps/cli/packages/cli/first/
/apps/cli/packages/cli/from-env/
/apps/cli/packages/cli/workspace/
